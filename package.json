{
  "name": "agent-monitor",
  "version": "1.0.0",
  "description": "Agent Monitor + Meeting Visualization System",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:dashboard": "cd dashboard && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:dashboard\"",
    "test": "node --test tests/integration/api.test.js",
    "test:unit": "node --test tests/unit/*.test.js"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "fastify": "^4.26.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
